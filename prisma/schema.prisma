// Review draft only.
// Do not run migrations from this schema until the model names, relations,
// enum values, and constraints are reviewed.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  SUPPORT
  ADMIN
  OWNER
}

enum SessionType {
  WEB
  DESKTOP
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  EXPIRED
  PAUSED
}

enum EntitlementStatus {
  ACTIVE
  INACTIVE
  EXPIRED
  REVOKED
  GRACE_PERIOD
}

enum EntitlementSource {
  SUBSCRIPTION
  TRIAL
  ADMIN
  MANUAL
  LEMON_SQUEEZY
}

enum DeviceStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum BillingProfileType {
  INDIVIDUAL
  COMPANY
}

enum BillingProfileStatus {
  COMPLETE
  MISSING_INFO
  NEEDS_REVIEW
}

enum BillingRequestType {
  CANCEL_TRIAL
  CANCEL_SUBSCRIPTION
  REFUND
}

enum BillingRequestStatus {
  OPEN
  REVIEWING
  APPROVED
  REJECTED
  COMPLETED
}

enum BillingRequestReason {
  TRIAL_NOT_NEEDED
  PRICE_TOO_HIGH
  OCR_NOT_ENOUGH
  TECHNICAL_PROBLEM
  BOUGHT_BY_MISTAKE
  DUPLICATE_PAYMENT
  CUSTOMER_SERVICE
  OTHER
}

enum WebhookEventStatus {
  PENDING
  PROCESSED
  FAILED
  IGNORED
}

enum AuditEventType {
  USER_LOGIN
  DESKTOP_SESSION_CREATED
  DESKTOP_SESSION_REVOKED
  DEVICE_REGISTERED
  DEVICE_REVOKED
  ENTITLEMENT_ACTIVATED
  ENTITLEMENT_REVOKED
  ENTITLEMENT_EXPIRED
  SUBSCRIPTION_UPDATED
  PAYMENT_SUCCEEDED
  PAYMENT_FAILED
  WEBHOOK_PROCESSED
  WEBHOOK_FAILED
  ADMIN_ACTION
}

enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
}

enum AnnouncementType {
  GUNCELLEME
  BILGILENDIRME
  BAKIM
  YENI_OZELLIK
}

enum AccessRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum FeatureSuggestionStatus {
  PENDING
  APPROVED
  REJECTED
  PLANNED
  IN_PROGRESS
  DONE
  ARCHIVED
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  username         String?   @unique
  name             String?
  staffTitle       String?
  staffPermissions String[]  @default([])
  passwordHash     String?
  role             UserRole  @default(USER)
  twoFactorEnabled Boolean   @default(false)
  emailVerifiedAt  DateTime?
  disabledAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  sessions               Session[]
  subscriptions          Subscription[]
  lemonSqueezyCustomers  LemonSqueezyCustomer[]
  entitlements           Entitlement[]
  devices                Device[]
  payments               Payment[]
  invoices               Invoice[]
  billingProfiles        BillingProfile[]
  billingRequests        BillingRequest[]
  accessRequests         AccessRequest[]
  supportTickets         SupportTicket[]
  featureSuggestions     FeatureSuggestion[]
  featureSuggestionVotes FeatureSuggestionVote[]
  memberships            Membership[]
  adminActions           AdminAction[]           @relation("AdminActionsByUser")
  targetedActions        AdminAction[]           @relation("AdminActionsForUser")
  admin2FA               Admin2FA?
  auditEvents            AuditLog[]              @relation("AuditActor")
  targetedEvents         AuditLog[]              @relation("AuditTarget")
  passwordResetTokens    PasswordResetToken[]

  @@index([role])
  @@index([username])
  @@index([disabledAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([expiresAt])
}

model Session {
  id         String      @id @default(cuid())
  userId     String
  productId  String?
  deviceId   String?
  type       SessionType
  tokenHash  String      @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  lastUsedAt DateTime?
  createdAt  DateTime    @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  device  Device?  @relation(fields: [deviceId], references: [id], onDelete: SetNull)

  @@index([userId, type])
  @@index([productId])
  @@index([deviceId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model Product {
  id        String        @id @default(cuid())
  slug      String        @unique
  name      String
  status    ProductStatus @default(ACTIVE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  subscriptions   Subscription[]
  entitlements    Entitlement[]
  devices         Device[]
  sessions        Session[]
  payments        Payment[]
  invoices        Invoice[]
  billingRequests BillingRequest[]
  versions        ProductVersion[]
  accessRequests  AccessRequest[]

  @@index([status])
}

model ProductVersion {
  id             String   @id @default(cuid())
  productId      String
  version        String
  minimumVersion String?
  releaseNotes   String?
  filePath       String
  sha256         String
  createdAt      DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([productId, version])
  @@index([productId, createdAt])
}

model AccessRequest {
  id           String              @id @default(cuid())
  userId       String
  email        String
  productCode  String
  productId    String?
  status       AccessRequestStatus @default(PENDING)
  reviewedById String?
  reviewedAt   DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@unique([userId, productCode])
  @@index([status, createdAt])
  @@index([productCode])
}

model Subscription {
  id                     String             @id @default(cuid())
  userId                 String
  productId              String
  provider               String
  providerCustomerId     String?
  providerSubscriptionId String
  providerVariantId      String?
  status                 SubscriptionStatus
  renewsAt               DateTime?
  endsAt                 DateTime?
  trialEndsAt            DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  user                 User                  @relation(fields: [userId], references: [id], onDelete: Restrict)
  product              Product               @relation(fields: [productId], references: [id], onDelete: Restrict)
  entitlements         Entitlement[]
  payments             Payment[]
  invoices             Invoice[]
  billingRequests      BillingRequest[]
  lemonSqueezyLicenses LemonSqueezyLicense[]

  @@unique([provider, providerSubscriptionId])
  @@index([provider, providerCustomerId])
  @@index([userId, productId])
  @@index([status])
}

model LemonSqueezyCustomer {
  id             String   @id @default(cuid())
  userId         String
  lemonSqueezyId String   @unique
  email          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([email])
}

model LemonSqueezyLicense {
  id              String   @id @default(cuid())
  userId          String
  subscriptionId  String?
  licenseKeyId    String   @unique
  licenseKey      String?
  activationLimit Int?
  status          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([subscriptionId])
  @@index([status])
}

model LemonSqueezyWebhookEvent {
  id          String    @id @default(cuid())
  eventId     String    @unique
  eventName   String
  payload     Json
  processedAt DateTime?
  error       String?
  createdAt   DateTime  @default(now())

  @@index([eventName])
  @@index([processedAt])
  @@index([createdAt])
}

model Entitlement {
  id             String            @id @default(cuid())
  userId         String
  productId      String
  subscriptionId String?
  status         EntitlementStatus
  source         EntitlementSource
  startsAt       DateTime          @default(now())
  expiresAt      DateTime?
  revokedAt      DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Restrict)
  product      Product       @relation(fields: [productId], references: [id], onDelete: Restrict)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([userId, productId])
  @@index([userId, productId, source])
  @@index([productId, status])
  @@index([subscriptionId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model Device {
  id              String       @id @default(cuid())
  userId          String
  productId       String
  deviceName      String?
  fingerprintHash String
  os              String?
  appVersion      String?
  launcherVersion String?
  status          DeviceStatus @default(ACTIVE)
  lastSeenAt      DateTime?
  trustedUntil    DateTime?
  revokedAt       DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Restrict)
  product  Product   @relation(fields: [productId], references: [id], onDelete: Restrict)
  sessions Session[]

  @@unique([userId, productId, fingerprintHash])
  @@index([userId, productId])
  @@index([trustedUntil])
  @@index([revokedAt])
}

model DownloadLog {
  id          String   @id @default(cuid())
  userId      String?
  productSlug String
  success     Boolean
  reason      String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([productSlug])
  @@index([success])
  @@index([createdAt])
}

model Payment {
  id               String        @id @default(cuid())
  userId           String
  productId        String
  subscriptionId   String?
  billingProfileId String?
  provider         String
  providerOrderId  String
  amount           Int
  currency         String
  status           PaymentStatus
  testMode         Boolean       @default(false)
  paidAt           DateTime?
  createdAt        DateTime      @default(now())

  user            User             @relation(fields: [userId], references: [id], onDelete: Restrict)
  product         Product          @relation(fields: [productId], references: [id], onDelete: Restrict)
  subscription    Subscription?    @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  billingProfile  BillingProfile?  @relation(fields: [billingProfileId], references: [id], onDelete: SetNull)
  invoices        Invoice[]
  billingRequests BillingRequest[]

  @@unique([provider, providerOrderId])
  @@index([userId, productId])
  @@index([subscriptionId])
  @@index([billingProfileId])
  @@index([status])
  @@index([testMode])
  @@index([paidAt])
}

model Invoice {
  id                String    @id @default(cuid())
  userId            String
  productId         String
  subscriptionId    String?
  billingProfileId  String?
  paymentId         String?
  provider          String
  providerInvoiceId String
  invoiceUrl        String?
  downloadUrl       String?
  issuedAt          DateTime?
  createdAt         DateTime  @default(now())

  user           User            @relation(fields: [userId], references: [id], onDelete: Restrict)
  product        Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  subscription   Subscription?   @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  billingProfile BillingProfile? @relation(fields: [billingProfileId], references: [id], onDelete: SetNull)
  payment        Payment?        @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@unique([provider, providerInvoiceId])
  @@index([userId, productId])
  @@index([subscriptionId])
  @@index([billingProfileId])
  @@index([paymentId])
  @@index([issuedAt])
}

model BillingProfile {
  id           String               @id @default(cuid())
  userId       String
  type         BillingProfileType
  status       BillingProfileStatus @default(MISSING_INFO)
  fullName     String?
  companyTitle String?
  email        String?
  phone        String?
  country      String?              @default("TR")
  city         String?
  district     String?
  postalCode   String?
  addressLine  String?
  tckn         String?
  vkn          String?
  taxOffice    String?
  isDefault    Boolean              @default(false)
  verifiedAt   DateTime?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Restrict)
  payments Payment[]
  invoices Invoice[]

  @@index([userId, isDefault])
  @@index([status])
  @@index([vkn])
  @@index([tckn])
}

model BillingRequest {
  id             String               @id @default(cuid())
  userId         String
  productId      String
  subscriptionId String?
  paymentId      String?
  type           BillingRequestType
  status         BillingRequestStatus @default(OPEN)
  reason         BillingRequestReason
  message        String?
  adminNote      String?
  reviewedById   String?
  reviewedAt     DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Restrict)
  product      Product       @relation(fields: [productId], references: [id], onDelete: Restrict)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  payment      Payment?      @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([productId, status])
  @@index([subscriptionId])
  @@index([paymentId])
  @@index([type, status])
  @@index([createdAt])
}

model WebhookEvent {
  id           String             @id @default(cuid())
  provider     String
  eventId      String
  eventType    String
  payloadHash  String?
  payload      Json
  status       WebhookEventStatus @default(PENDING)
  processedAt  DateTime?
  errorMessage String?
  createdAt    DateTime           @default(now())

  @@unique([provider, eventId])
  @@index([provider, eventType])
  @@index([status])
  @@index([createdAt])
}

model AuditLog {
  id            String         @id @default(cuid())
  actorUserId   String?
  targetUserId  String?
  adminActionId String?
  eventType     AuditEventType
  entityType    String?
  entityId      String?
  metadata      Json?
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime       @default(now())

  actor       User?        @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  target      User?        @relation("AuditTarget", fields: [targetUserId], references: [id], onDelete: SetNull)
  adminAction AdminAction? @relation(fields: [adminActionId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([targetUserId])
  @@index([eventType])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model AdminAction {
  id           String   @id @default(cuid())
  adminUserId  String
  targetUserId String?
  action       String
  reason       String?
  metadata     Json?
  createdAt    DateTime @default(now())

  admin      User       @relation("AdminActionsByUser", fields: [adminUserId], references: [id], onDelete: Restrict)
  targetUser User?      @relation("AdminActionsForUser", fields: [targetUserId], references: [id], onDelete: SetNull)
  auditLogs  AuditLog[]

  @@index([adminUserId])
  @@index([targetUserId])
  @@index([action])
  @@index([createdAt])
}

model AdminActionLog {
  id           String   @id @default(cuid())
  adminId      String
  targetUserId String?
  action       String
  before       Json?
  after        Json?
  ipAddress    String?
  createdAt    DateTime @default(now())

  @@index([adminId])
  @@index([targetUserId])
  @@index([action])
  @@index([createdAt])
}

model Admin2FA {
  id            String   @id @default(cuid())
  userId        String   @unique
  secret        String
  verified      Boolean  @default(false)
  recoveryCodes String[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)
}

model UserNote {
  id        String   @id @default(cuid())
  userId    String
  adminId   String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([adminId])
  @@index([createdAt])
}

model Organization {
  id           String    @id @default(cuid())
  name         String
  billingEmail String?
  archivedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  memberships Membership[]

  @@index([archivedAt])
}

model Membership {
  id             String         @id @default(cuid())
  userId         String
  organizationId String
  role           MembershipRole @default(MEMBER)
  removedAt      DateTime?
  createdAt      DateTime       @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Restrict)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  @@unique([userId, organizationId])
  @@index([organizationId, role])
  @@index([removedAt])
}

model Announcement {
  id          String           @id @default(cuid())
  title       String
  body        String
  type        AnnouncementType
  imageUrl    String?
  productSlug String?
  isPublished Boolean          @default(false)
  startsAt    DateTime?
  endsAt      DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([isPublished, startsAt, endsAt])
  @@index([createdAt])
  @@index([type])
}

model SupportTicket {
  id             String   @id @default(cuid())
  userId         String
  productSlug    String
  appVersion     String?
  issueType      String
  message        String
  status         String   @default("OPEN")
  sourceFileName String?
  systemSummary  Json?
  adminNote      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user        User                @relation(fields: [userId], references: [id], onDelete: Restrict)
  attachments SupportAttachment[]

  @@index([userId])
  @@index([productSlug])
  @@index([status])
  @@index([createdAt])
}

model SupportAttachment {
  id          String   @id @default(cuid())
  ticketId    String
  kind        String
  fileName    String
  contentType String
  sizeBytes   Int
  content     Bytes
  createdAt   DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([kind])
}

model FeatureSuggestion {
  id          String                  @id @default(cuid())
  userId      String
  productSlug String                  @default("fis260")
  appVersion  String?
  title       String
  description String
  status      FeatureSuggestionStatus @default(PENDING)
  adminNote   String?
  score       Int                     @default(0)
  upvotes     Int                     @default(0)
  downvotes   Int                     @default(0)
  reviewedAt  DateTime?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  user  User                    @relation(fields: [userId], references: [id], onDelete: Restrict)
  votes FeatureSuggestionVote[]

  @@index([userId])
  @@index([productSlug, status])
  @@index([score])
  @@index([createdAt])
}

model FeatureSuggestionVote {
  id           String   @id @default(cuid())
  suggestionId String
  userId       String
  value        Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  suggestion FeatureSuggestion @relation(fields: [suggestionId], references: [id], onDelete: Cascade)
  user       User              @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([suggestionId, userId])
  @@index([userId])
  @@index([suggestionId])
}
